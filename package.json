{
  "name": "vocabili-video-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:controller": "pnpm --filter vocabili-controller dev",
    "dev:remotion": "pnpm --filter vocabili-remotion dev",
    "build": "pnpm --filter vocabili-controller build && pnpm --filter vocabili-remotion build",
    "build:controller": "pnpm --filter vocabili-controller build",
    "build:remotion": "pnpm --filter vocabili-remotion build",
    "start": "pnpm --filter vocabili-controller start",
    "lint": "pnpm --filter vocabili-controller lint && pnpm --filter vocabili-remotion lint",
    "lint:controller": "pnpm --filter vocabili-controller lint",
    "lint:remotion": "pnpm --filter vocabili-remotion lint"
  }
}