{
  "name": "vocabili-video-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",

  "scripts": {
    "install:all": "pnpm install --no-frozen-lockfile",
    "dev:controller": "pnpm --filter controller dev",
    "dev:remotion": "pnpm --filter vocabili-remotion dev",
    "dev:panel": "pnpm --filter panel dev",
    "dev": "pnpm --filter controller dev & pnpm --filter vocabili-remotion dev & pnpm --filter vocabili-panel dev",
    "build": "pnpm --filter controller build && pnpm --filter vocabili-remotion build && pnpm --filter vocabili-panel build",
    "build:controller": "pnpm --filter controller build",
    "build:remotion": "pnpm --filter vocabili-remotion build",
    "build:panel": "pnpm --filter panel build",
    "start": "pnpm --filter controller start",
    "lint": "pnpm --filter controller lint && pnpm --filter vocabili-remotion lint && pnpm --filter vocabili-panel lint",
    "lint:controller": "pnpm --filter controller lint",
    "lint:remotion": "pnpm --filter vocabili-remotion lint",
    "clean": "rm -rf node_modules packages/*/node_modules pnpm-lock.yaml",
    "clean:install": "pnpm run clean && pnpm install --no-frozen-lockfile",
    "workspace:info": "pnpm -r list",
    "add": "pnpm add",
    "add:controller": "pnpm --filter controller add",
    "add:remotion": "pnpm --filter vocabili-remotion add",
    "add:shared": "pnpm --filter shared-config add",
    "add:panel": "pnpm --filter panel add"
  }
}